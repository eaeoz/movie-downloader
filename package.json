{
  "name": "movie-downloader",
  "version": "1.0.0",
  "description": "Modern torrent downloader with Letterboxd integration",
  "main": "main.js",
  "scripts": {
    "build": "tsc && node create-icon.js && npx electron-builder --win --x64 --publish never",
    "start": "node server.js",
    "dev": "ts-node server.ts",
    "electron": "electron .",
    "build:icon": "node create-icon.js",
    "build:portable": "npx electron-builder --win portable --x64 --publish never",
    "build:setup": "npx electron-builder --win nsis --x64 --publish never",
    "build:all": "npm run build:icon && npx electron-builder --win --x64 --publish never"
  },
  "build": {
    "appId": "com.moviedownloader.app",
    "productName": "Movie Downloader",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "../tor-dl/dist",
        "to": "tor-dl/dist",
        "filter": ["**/*"]
      },
      {
        "from": "../tor-dl/node_modules",
        "to": "tor-dl/node_modules",
        "filter": ["**/*"]
      },
      {
        "from": "../tor-dl",
        "to": "tor-dl",
        "filter": ["*.json", "sources.json"]
      }
    ],
    "asar": false,
    "forceCodeSigning": false,
    "win": {
      "icon": "data/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "installerIcon": "data/icon.ico",
      "uninstallerIcon": "data/icon.ico",
      "installerHeaderIcon": "data/icon.ico",
      "artifactName": "${productName} Setup ${version}.${ext}",
      "shortcutName": "Movie Downloader"
    },
    "portable": {
      "artifactName": "${productName}_portable_${version}.${ext}"
    }
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "webtorrent": "1.9.7"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "torrent",
    "downloader",
    "letterboxd",
    "movie"
  ],
  "license": "MIT"
}
